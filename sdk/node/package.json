{
  "name": "@otok/node",
  "version": "0.1.1",
  "description": "Official Node.js SDK for the oToK marketing platform public API (/v1) — contacts, deals, transactional email, webhooks, and a high-level e-commerce layer.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "otok",
    "marketing",
    "crm",
    "sdk",
    "api-client",
    "e-commerce",
    "webhooks",
    "transactional-email"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SlikkDev/otok-api.git",
    "directory": "sdk/node"
  },
  "homepage": "https://github.com/SlikkDev/otok-api/tree/main/sdk/node#readme",
  "bugs": {
    "url": "https://github.com/SlikkDev/otok-api/issues"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
