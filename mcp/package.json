{
  "name": "@otok/mcp",
  "version": "0.1.0",
  "description": "Official MCP (Model Context Protocol) server for the oToK marketing platform — exposes the public /v1 API to AI assistants, starting with the email-marketing surface (email campaigns + smart newsletters).",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "otok-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "otok",
    "mcp",
    "model-context-protocol",
    "ai",
    "email-marketing",
    "newsletters",
    "campaigns"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SlikkDev/otok-api.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/SlikkDev/otok-api/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/SlikkDev/otok-api/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@otok/node": "^0.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
